SKARLY_ENV=local
AUTH_MODE=firebase_with_guest

SKARLY_REPOSITORY_BACKEND=sqlite
SKARLY_STORAGE_BACKEND=local
SKARLY_LOCAL_STORAGE_DIR=.local-storage
SKARLY_LOCAL_BASE_URL=http://127.0.0.1:8090

SKARLY_WORKER_BACKEND=mvp_audio
SKARLY_MUSIC_GENERATOR_BACKEND=ace_step
SKARLY_MAX_DEMO_DURATION_SECONDS=300
ACE_STEP_ENABLED=true
PROCEDURAL_FALLBACK_ENABLED=false
SKARLY_ACE_STEP_BASE_URL=http://127.0.0.1:8001
# Leave command names as-is when they are available on PATH; otherwise set absolute paths in your local .env.
SKARLY_ACE_STEP_API_COMMAND=acestep-api
SKARLY_ACE_STEP_TIMEOUT_SECONDS=1800
SKARLY_ACE_STEP_DOWNLOAD_TIMEOUT_SECONDS=1800
SKARLY_ACE_STEP_INFER_STEP=20
SKARLY_ACE_STEP_GUIDANCE_SCALE=15
SKARLY_ACE_STEP_MAX_DURATION_SECONDS=300
SKARLY_ACE_STEP_USE_SOURCE_AUDIO=false
SKARLY_ACE_STEP_SEND_LYRICS=false
SKARLY_ACE_STEP_FALLBACK_TO_PROCEDURAL=false
REQUIRE_CUDA=true
ALLOW_CPU_GENERATION_FALLBACK=false
SKARLY_ACE_STEP_DIRECT_ENABLED=false
# Set only to a release-approved JSON produced by training/calibrate_diversity.py.
SKARLY_DIVERSITY_CALIBRATION_PATH=
SKARLY_AUDIOCRAFT_BACKEND_STATUS=blocked_windows_av_dependency

SKARLY_STEM_SEPARATOR_BACKEND=demucs
SKARLY_DEMUCS_PATH=python -m demucs.separate
SKARLY_DEMUCS_MODEL=htdemucs
SKARLY_DEMUCS_TWO_STEMS=vocals

SKARLY_MELODY_ANALYZER_BACKEND=basic_pitch
SKARLY_BASIC_PITCH_PATH=basic-pitch
SKARLY_BASIC_PITCH_MODEL_SERIALIZATION=onnx
SKARLY_WHISPER_PATH=whisper
SKARLY_WHISPER_MODEL=base
SKARLY_WHISPER_TIMEOUT_SEC=300
SKARLY_BACKING_MIX_GAIN=0.24
SKARLY_INSTRUMENTAL_MIX_GAIN=1.05
SKARLY_TASK_BACKEND=inline
SKARLY_FFMPEG_PATH=ffmpeg
SKARLY_LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
SKARLY_LOCAL_LLM_MODEL=llama3.2:1b

SKARLY_CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
