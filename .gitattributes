# Keep generated research artifacts and model checkpoints byte-for-byte intact.
*.pdf binary
*.docx binary
*.png binary
*.jpg binary
*.jpeg binary
*.pt binary

# Keep source and notebook metadata consistent across platforms.
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.ipynb text eol=lf
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
